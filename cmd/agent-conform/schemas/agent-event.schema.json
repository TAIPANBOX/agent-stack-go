{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taipanbox.dev/agent-passport/v0.1/agent-event.schema.json",
  "title": "Agent Event",
  "description": "One JSON object per event, NDJSON when batched. See SPEC.md §6.",
  "type": "object",
  "required": ["schema", "ts", "source", "type", "agent_id"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "taipanbox.dev/agent-event/v0.1",
      "description": "Schema identifier and version."
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339, UTC."
    },
    "source": {
      "type": "string",
      "description": "Emitting product. See SPEC.md §6.2.",
      "enum": ["tokenfuse", "engram", "idryx", "qryx"]
    },
    "type": {
      "type": "string",
      "description": "Event type. Open registry per source, see SPEC.md §6.2 — not enum-restricted; new types may be added freely within a source.",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "agent_id": {
      "type": "string",
      "description": "Canonical agent identifier. See SPEC.md §3.1.",
      "pattern": "^agent://[a-z0-9.-]+/[a-z0-9._/-]+$",
      "maxLength": 255
    },
    "run_id": {
      "type": "string",
      "description": "Task execution correlation ID."
    },
    "on_behalf_of": {
      "type": "array",
      "description": "Delegation chain, root first. See SPEC.md §5.",
      "items": {
        "type": "string",
        "pattern": "^(agent|user)://"
      }
    },
    "data": {
      "type": "object",
      "description": "Free-form object, owned by the source product. Consumers MUST ignore unknown keys.",
      "additionalProperties": true
    },
    "prev_hash": {
      "type": "string",
      "description": "Tamper-evident chain link, when maintained by the emitting product.",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "additionalProperties": true
}
